{
  "name": "extractify-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for Extractify Web Scraper",
  "scripts": {
    "install:all": "npm install && cd backend && npm install",
    "start:backend": "cd backend && npm run start:dev",
    "start:frontend": "python app.py",
    "start:admin": "echo 'Open admin_app/index.html in your browser'",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
